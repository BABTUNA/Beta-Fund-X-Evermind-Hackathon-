# Copy to .env.local and fill in. Re-run `next build` after changing.

# Inferred URL pattern; override if Butterbase tells you a different one.
NEXT_PUBLIC_BUTTERBASE_BASE=https://api.butterbase.ai/v1

# Your Butterbase app slug or UUID.
NEXT_PUBLIC_BB_APP_ID=evernav

# Read-capable key. For the hackathon, the same bb_sk_ key the extension uses
# is acceptable. For production, generate a read-only key.
NEXT_PUBLIC_BB_READ_KEY=bb_sk_replace_me
