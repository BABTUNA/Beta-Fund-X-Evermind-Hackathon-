# Copy to .env.local and fill in. Re-run `next build` after changing.

# Butterbase REST base. Production: https://api.butterbase.ai/v1
NEXT_PUBLIC_BUTTERBASE_BASE=https://api.butterbase.ai/v1

# Your Butterbase app_id (returned by init_app). Looks like app_xxxxxxxxxxxx.
NEXT_PUBLIC_BB_APP_ID=app_0aemhsdroh0j

# Service key (bb_sk_...). Bypasses RLS — same key the extension uses.
# Rotate post-demo.
NEXT_PUBLIC_BB_READ_KEY=bb_sk_replace_me
